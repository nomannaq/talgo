# Copy this file to .env and fill in your credentials
# lakeapi authenticates via standard boto3 AWS credentials.
# Your Access Key and Secret Key come from the crypto-lake dashboard.

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Optional overrides
# LAKE_CACHE_PATH=/path/to/cache   (default: .lake_cache/ in working directory)
# DEFAULT_EXCHANGE=BINANCE_FUTURES
